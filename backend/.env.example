NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://openged:openged@localhost:5432/openged

JWT_SECRET=replace-with-long-random-secret
JWT_TTL=15m
REFRESH_TOKEN_TTL=7d
AUTH_MODE=LOCAL_ONLY
MASTER_ENCRYPTION_KEY=replace-with-32-byte-minimum-key
FORCE_HTTPS=false

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=openged
S3_ACCESS_KEY=openged
S3_SECRET_KEY=openged123
S3_FORCE_PATH_STYLE=true

SEARCH_ENABLED=false
SEARCH_URL=http://localhost:9200
SEARCH_INDEX_NAME=openged-documents

SSO_ENABLED=false
SSO_PROVIDER=oidc
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SAML_ENTRY_POINT=
SSO_GROUP_ROLE_MAP={"GED-Editors":["EDITOR"],"GED-Validators":["VALIDATOR"]}

EMAIL_ENABLED=false
EMAIL_FROM=no-reply@example.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
